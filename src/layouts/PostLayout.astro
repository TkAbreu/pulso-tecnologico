---
import BaseLayout from './BaseLayout.astro';
import PostHeader from '../components/PostHeader.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const { post } = Astro.props;

const categorySlug = post.data.category
  .toLowerCase()
  .normalize('NFD')
  .replace(/[̀-ͯ]/g, '');

const encodedTitle = encodeURIComponent(post.data.title);
const postURL      = `https://pulsotecnologico.com.br/blog/${post.id.replace(/\.md$/, '')}`;
const encodedURL   = encodeURIComponent(postURL);
const twitterURL   = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedURL}`;
const linkedinURL  = `https://www.linkedin.com/shareArticle?mini=true&url=${encodedURL}&title=${encodedTitle}`;

const relatedPosts = (
  await getCollection('blog', ({ data, id }) =>
    !data.draft && data.category === post.data.category && id !== post.id
  )
)
  .sort((a, b) => b.data.date - a.data.date)
  .slice(0, 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.cover}
  type="article"
  date={post.data.date.toISOString()}
  author={post.data.author}
>
  <div class="max-w-4xl mx-auto px-4 py-4">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-1.5 text-xs text-[#c8d8d0]/70 mb-8" aria-label="Caminho de navegação">
      <a href="/" class="hover:text-[#00c896] transition-colors">Home</a>
      <span aria-hidden="true">›</span>
      <a href={`/categoria/${categorySlug}`} class="hover:text-[#00c896] transition-colors capitalize">
        {post.data.category}
      </a>
      <span aria-hidden="true">›</span>
      <span class="text-[#c8d8d0] truncate max-w-xs">{post.data.title}</span>
    </nav>

    <PostHeader post={post} />

    <!-- AdSense: Banner topo do post 728x90 desktop / 320x50 mobile -->
    <div class="ad-slot ad-slot--top" aria-label="Publicidade"><!-- placeholder --></div>

    <div class="flex flex-col lg:flex-row gap-8">

      <article class="prose max-w-none flex-1 min-w-0 mx-auto" style="font-size: 18px; line-height: 1.8; max-width: 720px;">
        <!-- AdSense: In-article 468x60 -->
        <div class="ad-slot ad-slot--mid" aria-label="Publicidade"><!-- placeholder --></div>

        <slot />
      </article>

      <!-- Sidebar desktop -->
      <aside class="hidden xl:block shrink-0">
        <!-- AdSense: Sidebar 300x250 sticky -->
        <div class="ad-slot ad-slot--sidebar" aria-label="Publicidade"><!-- placeholder --></div>
      </aside>

    </div>

    <!-- AdSense: Retângulo 336x280 -->
    <div class="ad-slot ad-slot--bottom" aria-label="Publicidade"><!-- placeholder --></div>

    <!-- Compartilhar -->
    <div class="border-t border-[#0f2420] pt-8 mt-8">
      <p class="text-[#c8d8d0] text-xs uppercase tracking-widest mb-4">Compartilhar</p>
      <div class="flex flex-wrap gap-3">
        <a
          href={twitterURL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0f2420] hover:bg-[#00c896]/10 border border-[#0f2420] hover:border-[#00c896]/30 text-[#c8d8d0] hover:text-[#00c896] text-sm font-medium px-4 py-2.5 rounded-lg transition-all duration-200"
          aria-label="Compartilhar no Twitter/X"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.738l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          Twitter / X
        </a>
        <a
          href={linkedinURL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#0f2420] hover:bg-[#00c896]/10 border border-[#0f2420] hover:border-[#00c896]/30 text-[#c8d8d0] hover:text-[#00c896] text-sm font-medium px-4 py-2.5 rounded-lg transition-all duration-200"
          aria-label="Compartilhar no LinkedIn"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Tags -->
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="border-t border-[#0f2420] pt-8 mt-8">
        <p class="text-[#c8d8d0] text-xs uppercase tracking-widest mb-3">Tags</p>
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="bg-[#0f2420] text-[#c8d8d0] text-xs px-3 py-1.5 rounded-full border border-[#0f2420] hover:border-[#00c896]/30 hover:text-[#00c896] transition-all cursor-default">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Posts relacionados -->
    {relatedPosts.length > 0 && (
      <section class="border-t border-[#0f2420] pt-12 mt-12">
        <h2 class="text-2xl font-bold text-[#e8f4f0] mb-8">
          Mais artigos sobre {post.data.category}
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map((related) => (
            <PostCard post={related} />
          ))}
        </div>
      </section>
    )}

    <!-- Navegação de volta -->
    <div class="mt-12 pt-8 border-t border-[#0f2420]">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-[#00c896] hover:text-[#00e5a0] text-sm font-medium transition-colors duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Todos os artigos
      </a>
    </div>

  </div>
</BaseLayout>
