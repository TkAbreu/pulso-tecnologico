---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';

const {
  title,
  description,
  image,
  type = 'website',
  date,
  author,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Pulso Tecnológico" href="/rss.xml" />
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      date={date}
      author={author}
    />
  </head>
  <body class="min-h-screen bg-[#0a1a16] text-[#e8f4f0] antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-[#00c896] text-[#0a1a16] font-bold px-4 py-2 rounded z-50"
    >
      Ir para o conteúdo principal
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
