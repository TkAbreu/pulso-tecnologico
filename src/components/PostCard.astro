---
const { post } = Astro.props;
const slug = post.id.replace(/\.md$/, '');

const date = new Date(post.data.date).toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});

// Cores de categoria — dark-mode compatíveis
const categoryStyles = {
  'EDI':          'bg-cyan-950/70 text-cyan-300 hover:bg-cyan-900/60',
  'Produtividade':'bg-amber-950/70 text-amber-300 hover:bg-amber-900/60',
  'Tecnologia':   'bg-violet-950/70 text-violet-300 hover:bg-violet-900/60',
};

const catStyle = categoryStyles[post.data.category] ?? 'bg-[#00c896]/10 text-[#00c896] hover:bg-[#00c896]/20';
---

<article class="bg-[#0f2420] rounded-xl overflow-hidden border border-transparent hover:border-[#00c896]/25 hover:shadow-[0_4px_24px_rgba(0,200,150,0.08)] transition-all duration-300 group flex flex-col animate-fade-in-up">

  <!-- Imagem com gradiente de sobreposição -->
  <a href={`/blog/${slug}`} class="block relative overflow-hidden aspect-video bg-[#0a1a16]" tabindex="-1" aria-hidden="true">
    <img
      src={post.data.cover}
      alt={post.data.title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      width="640"
      height="360"
    />
    <!-- Gradiente de baixo para cima no hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f2420]/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </a>

  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-2 mb-3 flex-wrap">
      <a
        href={`/categoria/${post.data.category.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '')}`}
        class={`text-xs font-semibold px-2.5 py-1 rounded-full transition-colors ${catStyle}`}
      >
        {post.data.category}
      </a>
      <span class="text-[#c8d8d0] text-xs">{date}</span>
      <span class="text-[#c8d8d0]/60 text-xs">·</span>
      <span class="text-[#c8d8d0] text-xs">{post.data.readTime} min</span>
    </div>

    <a href={`/blog/${slug}`} class="block flex-1">
      <h2 class="text-[#e8f4f0] font-bold text-lg leading-snug mb-2 group-hover:text-[#00c896] transition-colors line-clamp-2">
        {post.data.title}
      </h2>
      <p class="text-[#c8d8d0] text-sm leading-relaxed line-clamp-3">
        {post.data.description}
      </p>
    </a>

    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-1.5 mt-5 text-[#00c896] text-sm font-medium hover:text-[#00e5a0] transition-colors self-start"
      aria-label={`Ler artigo: ${post.data.title}`}
    >
      Ler artigo
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>

</article>
